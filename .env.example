# ─── AI Video Assistant — Environment Variables ─────────────────────────────
# Copy this file to `.env` and fill in your API keys.
#   cp .env.example .env

# ─── Mistral AI (Required) ──────────────────────────────────────────────────
# Used for summarization, extraction, title generation, and RAG Q&A.
# Get your key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# ─── Sarvam AI (Optional — only needed for Hinglish transcription) ──────────
# Used for Hindi/Hinglish speech-to-text with English translation.
# Get your key at: https://www.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── Whisper Configuration (Optional) ───────────────────────────────────────
# Local Whisper model size: tiny, base, small, medium, large
# Larger models are more accurate but require more RAM/VRAM.
# Default: small
WHISPER_MODEL=small

# ─── Sarvam STT Model (Optional) ────────────────────────────────────────────
# Default: saaras:v2.5
SARVAM_STT_MODEL=saaras:v2.5
